# llama.cpp + GGUF アプローチ — driver 535 / CUDA 12 で最新モデル (Qwen3.5/Gemma-4) を動かす。
#
# vLLM は CUDA 13 必須化で driver 535 では動かないが、
# llama.cpp は CUDA 12 系で latest models GGUF を高速推論可能。
# trade-off: vllm より throughput 低い、TP 完成度低い (我々は 80 問評価なので問題なし)

FROM nvidia/cuda:12.4.1-devel-ubuntu22.04

ENV DEBIAN_FRONTEND=noninteractive \
    TZ=Asia/Tokyo \
    PYTHONUNBUFFERED=1 \
    CUDA_HOME=/usr/local/cuda \
    PATH=/usr/local/cuda/bin:$PATH

# OS deps + ビルドツール (libssl-dev は llama.cpp HTTPS サポートに必須)
RUN apt-get update && apt-get install -y --no-install-recommends \
        python3 python3-pip python3-dev \
        build-essential cmake ninja-build git wget curl jq ca-certificates \
        libcurl4-openssl-dev libssl-dev pkg-config \
        cuda-compat-12-4 && \
    apt-get clean && rm -rf /var/lib/apt/lists/*

ENV LD_LIBRARY_PATH=/usr/local/cuda-12.4/compat:/usr/local/cuda/lib64:${LD_LIBRARY_PATH}

RUN ln -sf /usr/bin/python3 /usr/bin/python && \
    pip install --no-cache-dir --upgrade pip

# --- llama.cpp ビルド (CUDA 12.4 で) ---
# CUDA arch list: A100 = sm_80
RUN git clone --depth 1 https://github.com/ggml-org/llama.cpp.git /tmp/llama.cpp && \
    cd /tmp/llama.cpp && \
    cmake -B build \
        -DGGML_CUDA=ON \
        -DCMAKE_CUDA_ARCHITECTURES=80 \
        -DLLAMA_CURL=ON \
        -DLLAMA_OPENSSL=ON \
        -DCMAKE_BUILD_TYPE=Release && \
    cmake --build build --config Release -j $(nproc) && \
    cmake --install build --prefix /usr/local && \
    ldconfig && \
    rm -rf /tmp/llama.cpp

# --- ベンチクライアント ---
RUN pip install --no-cache-dir \
        "openai>=1.30" \
        python-dotenv \
        tqdm \
        pandas \
        scipy \
        huggingface_hub \
        hf-transfer

ENV HF_HOME=/hf_cache \
    HUGGINGFACE_HUB_CACHE=/hf_cache/hub \
    HF_HUB_ENABLE_HF_TRANSFER=1

WORKDIR /work

# build 完了確認
RUN llama-server --version 2>&1 | head -5 || llama-server --help 2>&1 | head -5

CMD ["bash"]
